# OTTR Algorithmic Trading Environment Variables

# Language Settings ('en' or 'ru')
LOCALE=en

# Binance API Credentials
# Leave empty to use public endpoints (1200 weight limits)
# Fill to enable authenticated mode (6000 weight limits)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# LLM config is hot-swapped in the UI under "System parameters"
# No defaults required here.
