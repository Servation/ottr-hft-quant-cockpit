DISCORD_BOT_TOKEN=your-token-here
DISCORD_TRADING_FLOOR_CHANNEL_ID=123456789012345678
DISCORD_SYSTEM_STATUS_CHANNEL_ID=123456789012345679
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL_ID=gemma-4-12b
CEO_DISCORD_ID=your-discord-id-here

# Safety kill-switch: when set to 1/true, execute_trade, update_parameter, and
# cancel_orders are blocked (no-op + logged). Read tools still work.
TRADING_DRY_RUN=0

# Shared secret required on ALL state-changing API calls (bridge /api/directive
# and the agent-gateway mutation routes). Endpoints FAIL CLOSED without it.
# Use the SAME value for discord-bridge and agent-gateway. Generate a long random
# string, e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`.
OTTR_API_KEY=change-me-to-a-long-random-secret

# Optional per-trade notional cap (USD). When > 0, execute_trade rejects any
# single order whose notional exceeds it (defense-in-depth vs runaway/injected
# orders). 0 or unset = no cap.
MAX_TRADE_USD=0

# --- Rate limiting / CORS (Phase 3) ---
# Minimum seconds between accepted CEO messages (throttles LLM dispatch).
CEO_MIN_INTERVAL_SEC=2
# Max requests/min per client IP on state-changing endpoints (bridge + gateway).
API_RATE_LIMIT=30
# Gateway CORS allow-list (comma-separated). Restrict to your dashboard origin(s).
GATEWAY_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
